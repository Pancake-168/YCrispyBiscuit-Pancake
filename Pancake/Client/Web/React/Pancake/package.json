{
  "name": "pancake",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:electron": "chcp 65001>nul & cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true ELECTRON_DEV_TOOLS=true node scripts/electron-dev.js",
    "dev:electron:prod": "chcp 65001>nul & cross-env ELECTRON_DEV_TOOLS=false node scripts/electron-dev.js",
    "build": "tsc -b && vite build",
    "build:electron": "chcp 65001>nul & cross-env HTTP_PROXY=http://127.0.0.1:7897 HTTPS_PROXY=http://127.0.0.1:7897 NO_PROXY=localhost,127.0.0.1 vue-tsc -b && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "lint": "eslint .",
    "format": "prettier --check . --ignore-path .prettierignore",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron": "^41.1.0",
    "i18next": "^25.10.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.1",
    "react-router-dom": "^7.13.1",
    "save": "^2.9.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}