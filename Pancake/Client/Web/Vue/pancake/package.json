{
  "name": "pancake",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:electron": "chcp 65001>nul & cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true ELECTRON_DEV_TOOLS=true node scripts/electron-dev.js",
    "dev:electron:prod": "chcp 65001>nul & cross-env ELECTRON_DEV_TOOLS=false node scripts/electron-dev.js",
    "build": "vue-tsc -b && vite build",
    "build:electron": "chcp 65001>nul & cross-env HTTP_PROXY=http://127.0.0.1:7897 HTTPS_PROXY=http://127.0.0.1:7897 NO_PROXY=localhost,127.0.0.1 vue-tsc -b && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-remove-console": "^2.2.0",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  }
}
