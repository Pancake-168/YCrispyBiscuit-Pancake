  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.8.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
