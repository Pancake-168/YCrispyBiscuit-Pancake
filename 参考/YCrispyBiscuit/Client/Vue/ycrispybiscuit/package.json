{
  "name": "ycrispybiscuit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "chcp 65001>nul & cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true ELECTRON_DEV_TOOLS=true node scripts/electron-dev.js",
    "dev:electron:prod": "chcp 65001>nul & cross-env ELECTRON_DEV_TOOLS=false node scripts/electron-dev.js",
    "build": "vue-tsc -b && vite build",
    "build:electron": "chcp 65001>nul & cross-env HTTP_PROXY=http://127.0.0.1:7897 HTTPS_PROXY=http://127.0.0.1:7897 NO_PROXY=localhost,127.0.0.1 vue-tsc -b && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "electron-store": "^11.0.2",
    "pinia": "^3.0.4",
    "vite-plugin-remove-console": "^2.2.0",
    "vue": "^3.5.24",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.ycrispybiscuit.vue",
    "productName": "YCrispyBiscuitVue",
    "icon": "public/icon.png",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      ".env.production"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "YCrispyBiscuit_Setup_${version}.${ext}"
    },
    "extraMetadata": {
      "type": "commonjs"
    }
  }
}
