{
  "name": "RegionAI",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:electron": "chcp 65001>nul & cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true ELECTRON_DEV_TOOLS=true node scripts/electron-dev.js",
    "dev:electron:prod": "chcp 65001>nul & cross-env ELECTRON_DEV_TOOLS=false node scripts/electron-dev.js",
    "build": "vue-tsc -b && vite build",
    "build:electron": "chcp 65001>nul & cross-env HTTP_PROXY=http://127.0.0.1:7897 HTTPS_PROXY=http://127.0.0.1:7897 NO_PROXY=localhost,127.0.0.1 vue-tsc -b && vite build && tsc -p electron/tsconfig.json && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@nocobase/client": "2.0.0-beta.1",
    "@types/dompurify": "^3.2.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "commonmark": "^0.31.2",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "echarts": "^6.0.0",
    "electron-store": "^11.0.2",
    "linkify-html": "^4.3.2",
    "linkify-string": "^4.3.2",
    "linkifyjs": "^4.3.2",
    "lodash-es": "^4.17.23",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.1",
    "markdown-it-highlightjs": "^4.3.0",
    "matrix-js-sdk": "^40.1.0-rc.0",
    "pinia": "^3.0.4",
    "vite-plugin-remove-console": "^2.2.0",
    "vue": "^3.5.24",
    "vue-flow": "^0.3.0",
    "vue-i18n": "^11.2.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/commonmark": "^0.27.10",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.0.0",
    "sass-embedded": "^1.97.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.RegionAI.vue",
    "productName": "RegionAI",
    "icon": "public/icon.png",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      ".env.production"
    ],
    "win": {
      "icon": "public/icon.png",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "RegionAI_Setup_${version}.${ext}"
    },
    "extraMetadata": {
      "type": "commonjs"
    }
  },
  "packageManager": "npm@10.5.0"
}
